    pipeline {
        // tool { 'nodejs' }
        agent {any 'any'}
        environment {
        AWS_REGION = 'ap-southeast-1'
        ECR_REPO = 'pythonapplicationdocker'
        AWS_ACCOUNT_ID = '891377182218'
        URL_REGISTRY = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
        NAME= "testpython"
    }
        stages {

            stage ('SCM') { 
                steps {
                    checkout scm
                }
            }

            stage ('Docker Login') {
                steps {
                    script {
                    withCredentials([usernamePassword(credentialsId: 'ECR-DEMO-CREDS', usernameVariable: 'AWS_ACCESS_KEY_ID', passwordVariable: 'AWS_SECRET_ACCESS_KEY')]) {
                        // Login to ECR
                        sh "aws ecr get-login-password --region ${AWS_REGION} | docker login --username AWS --password-stdin ${URL_REGISTRY}"
                    }
                }
             }
            }

            stage ('Removing Exisitng container and imges') {
                steps {
                    sh "docker rmi $NAME"
                }
            }
            stage ('Build Docker Image') {
                steps {
                    sh "docker build -t $NAME ."
                }

            } 
        }
    }
