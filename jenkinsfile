node {
    def application = "pythonapplicationdocker"
    def awsRegion = "ap-southeast-1" // Replace with your AWS region
    def ecrRegistryUrl = "891377182218.dkr.ecr.ap-southeast-1.amazonaws.com/pythonapplicationdocker" // Replace with your ECR registry URL
    def imageName = "${ecrRegistryUrl}/${application}:${BUILD_NUMBER}"

    stage('Clone repository') {
        checkout scm
    }

    stage('Build image') {
        app = docker.build(imageName)
    }

    stage('Push image to ECR') {
        withDockerRegistry([credentialsId: "891377182218", url:891377182218.dkr.ecr.ap-southeast-1.amazonaws.com/pythonapplicationdocker]) {
            app.push()
            docker.image(imageName).push('latest')
        }
    }

    stage('Deploy') {
        sh("docker run -d -p 3333:3333 ${imageName}")
    }

    stage('Remove old images') {
        sh("docker rmi ${imageName} -f")
    }
}

