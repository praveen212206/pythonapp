pipeline {
    agent any
    environment {
        AWS_DEFAULT_REGION = 'ap-southeast-1'
        ECR_REPO = 'pythonapplicationdocker'
        AWS_ACCOUNT_ID = '891377182218'
        URL_REGISTRY = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_DEFAULT_REGION}.amazonaws.com"
        NAME = "testpython"
    }
    stages {
        stage ('SCM') {
            steps {
                checkout scm
            }
        }

        stage ('Docker Login') {
            steps {
                script {
                    withCredentials([usernamePassword(credentialsId: 'ECR_CREDS', usernameVariable: 'AWS_ACCESS_KEY_ID', passwordVariable: 'AWS_SECRET_ACCESS_KEY')]) {
                        def ecrLoginCmd = "aws ecr get-login-password --region ${AWS_DEFAULT_REGION}"
                        def ecrPassword = sh(script: ecrLoginCmd, returnStdout: true).trim()
                        
                        // Docker login to ECR
                        def dockerLoginCmd = "docker login --username AWS --password ${ecrPassword} ${URL_REGISTRY}"
                        sh dockerLoginCmd
                    }
                }
            }
        }

        stage ('Removing Existing Container and Images') {
            steps {
                sh "docker rmi $NAME || true"  // Use || true to ignore errors if image doesn't exist
            }
        }

        stage ('Build Docker Image') {
            steps {
                sh "docker build -t $NAME ."
            }
        }

        stage ('Push to ECR') {
            steps {
                script {
                    // Tag and push Docker image to ECR
                    sh "docker tag $NAME ${URL_REGISTRY}/${ECR_REPO}:latest"
                    sh "docker push ${URL_REGISTRY}/${ECR_REPO}:latest"
                }
            }
        }
    }
}
