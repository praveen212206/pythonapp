pipeline {
    agent any
    environment {
        AWS_REGION = 'ap-southeast-1'
        ECR_REPO = 'pythonapplicationdocker'
        AWS_ACCOUNT_ID = '891377182218'
        URL_REGISTRY = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
        NAME = "testpython"
    }
    stages {
        stage ('SCM') {
            steps {
                checkout scm
            }
        }

        stage ('Docker Login') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'ECR_CREDS', usernameVariable: 'AWS_ACCESS_KEY_ID', passwordVariable: 'AWS_SECRET_ACCESS_KEY')]) {
                    script {
                        // Login to ECR
                        sh "aws ecr get-login-password --region ${AWS_REGION} | docker login --username AWS --password-stdin ${URL_REGISTRY}"
                    }
                }
            }
        }

        stage ('Removing Existing Container and Images') {
            steps {
                sh "docker rmi $NAME || true"  // Use || true to ignore errors if image doesn't exist
            }
        }

        stage ('Build Docker Image') {
            steps {
                sh "docker build -t $NAME ."
            }
        }

        stage ('Push to ECR') {
            steps {
                script {
                    sh "aws ecr-public get-login-password --region us-east-1 | docker login --username AWS --password-stdin public.ecr.aws/i1t4g6o8"
                    sh "docker tag $NAME ${URL_REGISTRY}/${ECR_REPO}:latest"
                    sh "docker push ${URL_REGISTRY}/${ECR_REPO}:latest"
                }
            }
        }
    }
}
