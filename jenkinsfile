    pipeline {
        // tool { 'nodejs' }
        agent {any 'any'}
        environment {
        AWS_REGION = 'ap-southeast-1'
        ECR_REPO = 'pythonapplicationdocker'
        AWS_ACCOUNT_ID = '891377182218'
        URL_REGISTRY = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
        NAME= "testpython"
    }
        stages {

            stage ('Docker Push Image') {
                steps {
                script {
                    withCredentials([usernamePassword(credentialsId: 'AWS_SECRET_KEYS', usernameVariable: 'AWS_SECRET_KEYS', passwordVariable: 'AWS_SECRET_KEYS')]) {
                    // Login to ECR
                        sh "aws ecr get-login-password --region ${AWS_REGION} | docker login --username AWS --password-stdin ${URL_REGISTRY}"
                    }
            }
            
            }

            stage ('SCM') { 
                steps {
                    checkout scm
                }
            }

            stage ('Removing Exisitng container and imges') {
                steps {
                    sh "docker rmi $NAME"
                }
            }
            stage ('Build Docker Image') {
                steps {
                    sh "docker build -t $NAME ."
                }

            }
 
        }
    }

    }
